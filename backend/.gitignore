# Backend .gitignore

# Dependencies
/node_modules
npm-debug.log
yarn-debug.log
yarn-error.log

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production

# Logs
logs
*.log

# Trained ML artifacts
/ml_models

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage
.grunt

# Bower dependency directory
bower_components

# MongoDB dump files
/dump

# Twilio credentials and API keys
twilio-credentials.json
api-keys.json
credentials.json

# Temporary files
.tmp
.temp

# Editor directories and files
.idea
.vscode
*.swp
*.swo
