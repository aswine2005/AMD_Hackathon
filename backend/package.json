{
  "name": "sales-forecasting-backend",
  "version": "1.0.0",
  "description": "Backend for Sales Forecasting ML application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seedData.js",
    "train:forecast": "node scripts/trainForecastModel.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\"",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit"
