  "keywords": [
    "sales",
    "forecasting",
    "machine learning",
    "prediction"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@huggingface/inference": "^3.13.0",
    "@tensorflow/tfjs": "^4.22.0",
    "axios": "^1.9.0",
    "body-parser": "^1.20.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "luxon": "^3.7.1",
    "mongoose": "^7.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.1",
    "nodemailer": "^6.10.1",
    "openai": "^4.98.0",
    "react-ga4": "^3.0.1",
    "twilio": "^5.5.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
