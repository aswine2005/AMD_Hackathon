# ─────────────────────────────────────────────
#  FRONTEND ENVIRONMENT VARIABLES
#  Copy this file → rename to .env (no .example)
#  Never commit .env to git!
# ─────────────────────────────────────────────

# Backend API URL
# Local development:
REACT_APP_API_URL=http://localhost:3456
# Production (uncomment when deployed):
# REACT_APP_API_URL=https://your-backend.onrender.com

# HuggingFace API Token — for AI chatbot
# Get from: huggingface.co/settings/tokens (Read token)
REACT_APP_HF_API_KEY=your_huggingface_read_token_here

# Google Analytics 4 — Measurement ID
# Get from: analytics.google.com → Admin → Data Streams → your stream → Measurement ID
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX
